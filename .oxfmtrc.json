{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "ignorePatterns": [
    "**/*.d.ts",
    "**/generated/**",
    "**/fixtures/**",
    "**/.wrangler/**",
    "**/*.json",
    "**/*.jsonc",
    "**/*.toml",
    "**/*.yml",
    "**/*.yaml",
    "**/*.html",
    "**/*.md",
    "**/*.mdx",
    "**/*.css",
    "**/*.example"
  ]
}
