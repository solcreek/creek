{
  "name": "@solcreek/adapter-nextjs",
  "version": "0.1.0",
  "description": "Creek deployment adapter for Next.js 16.2+ (Cloudflare Workers)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "creek",
    "nextjs",
    "adapter",
    "cloudflare",
    "workers"
  ],
  "author": "SolCreek",
  "license": "Apache-2.0",
  "homepage": "https://creek.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/solcreek/creek.git",
    "directory": "packages/adapter-nextjs"
  },
  "dependencies": {
    "@next/routing": "16.2.1",
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "next": ">=16.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "next": "16.2.1",
    "typescript": "^5.8.2"
  }
}
