name = "creek-realtime"
main = "src/index.ts"
compatibility_date = "2025-03-14"
workers_dev = true

[durable_objects]
bindings = [
  { name = "ROOMS", class_name = "RealtimeRoom" }
]

[[migrations]]
tag = "v1"
new_classes = ["RealtimeRoom"]

# Custom domain
[[routes]]
pattern = ""  # e.g. "rt.yourdomain.dev"
custom_domain = true

[vars]
REALTIME_SECRET = ""

# Per-project HMAC auth — set via: wrangler secret put REALTIME_MASTER_KEY
# When set, broadcast auth uses HMAC-SHA256(masterKey, projectSlug)
# Must match the same key in control-plane
