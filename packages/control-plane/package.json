{
  "name": "@solcreek/control-plane",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply creek-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply creek-db --remote"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.2",
    "@solcreek/sdk": "workspace:*",
    "better-auth": "^1.6.2",
    "cloudflare": "^5.2.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.2",
    "wrangler": "^4.82.2"
  }
}
